{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "displayName": { "type": "string", "description": "User display name" },
        "email": { "type": "string", "description": "User email" },
        "clanName": { "type": "string", "description": "Name of the clan the user belongs to" },
        "clanRole": { "type": "string", "description": "Role in the clan" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Clan": {
      "title": "Clan",
      "description": "Clan information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Clan name" },
        "members": { "type": "number", "description": "Number of members" },
        "description": { "type": "string", "description": "Clan description" }
      },
      "required": ["name", "members"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/clans/{name}": {
      "schema": { "$ref": "Clan" },
      "description": "Clan data"
    }
  }
}
