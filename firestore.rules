rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    //   - uid: string (required)
    //   - name: string (required)
    //   - username: string (required)
    //   - isOnline: boolean (optional)
    //   - lastSeen: timestamp (optional)
    //   - isAdmin: boolean (optional)
    //   - isVerified: boolean (optional)
    //   - createdAt: timestamp (required)
    // Collection: posts
    //   - userId: string (required)
    //   - likes: number (required)
    //   - comments: number (required)
    //   - createdAt: timestamp (required)
    // Collection: chats
    //   - participants: list (required)
    //   - updatedAt: timestamp (required)
    // Collection: chats/{chatId}/messages
    //   - chatId: string (required)
    //   - senderId: string (required)
    //   - createdAt: timestamp (required)
    // Collection: communities
    //   - name: string (required)
    //   - ownerId: string (required)
    //   - membersCount: number (required)
    //   - createdAt: timestamp (required)
    // Collection: communityMembers
    //   - userId: string (required)
    //   - communityId: string (required)
    //   - role: string (required)
    //   - joinedAt: timestamp (required)
    // Collection: friends
    //   - user1: string (required)
    //   - user2: string (required)
    //   - status: string (required)
    //   - createdAt: timestamp (required)

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          (request.auth.token.email == "alexeivasilev270819942@gmail.com" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
        (request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'name', 'username', 'createdAt']) &&
        isValidStringLength('uid', 1, 128) &&
        isValidStringLength('name', 1, 100) &&
        isValidStringLength('username', 1, 50) &&
        isValidOptionalString('location', 0, 100) &&
        isValidOptionalString('status', 0, 500) &&
        isValidOptionalString('profileImage', 0, 1000000) &&
        isValidOptionalString('coverImage', 0, 1000000) &&
        isValidOptionalString('github', 0, 100) &&
        isValidOptionalString('twitter', 0, 100) &&
        isValidOptionalString('instagram', 0, 100) &&
        isValidOptionalString('website', 0, 100) &&
        (!( 'isOnline' in request.resource.data ) || request.resource.data.isOnline is bool) &&
        (!( 'lastSeen' in request.resource.data ) || request.resource.data.lastSeen is timestamp) &&
        (!( 'isAdmin' in request.resource.data ) || request.resource.data.isAdmin is bool) &&
        (!( 'isVerified' in request.resource.data ) || request.resource.data.isVerified is bool) &&
        (!( 'isMuted' in request.resource.data ) || request.resource.data.isMuted is bool) &&
        (!( 'isBanned' in request.resource.data ) || request.resource.data.isBanned is bool) &&
        (!( 'isFrozen' in request.resource.data ) || request.resource.data.isFrozen is bool) &&
        (!( 'followersCount' in request.resource.data ) || request.resource.data.followersCount is number) &&
        request.resource.data.createdAt is timestamp;
    }

    function isUserPrivilegeUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isVerified', 'isMuted', 'isBanned', 'isFrozen']);
    }

    function isValidPost() {
      return hasRequiredFields(['userId', 'likes', 'comments', 'createdAt']) &&
        isValidStringLength('userId', 1, 128) &&
        request.resource.data.userId == request.auth.uid &&
        isValidOptionalString('text', 0, 2000) &&
        isValidOptionalString('image', 0, 1000000) &&
        request.resource.data.likes is number &&
        request.resource.data.comments is number &&
        request.resource.data.createdAt is timestamp;
    }

    function isValidPostUpdate() {
      let isOwnerUpdate = request.auth.uid == resource.data.userId && isValidPost();
      let isLikeUpdate = request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
                         request.resource.data.likes is number &&
                         (request.resource.data.likes - resource.data.likes == 1 || request.resource.data.likes - resource.data.likes == -1);
      return isOwnerUpdate || isLikeUpdate;
    }

    function isValidChat() {
      return hasRequiredFields(['participants', 'updatedAt']) &&
        request.resource.data.participants is list &&
        request.resource.data.participants.size() == 2 &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.updatedAt is timestamp;
    }

    function isValidMessage() {
      return hasRequiredFields(['chatId', 'senderId', 'createdAt']) &&
        request.resource.data.senderId == request.auth.uid &&
        isValidOptionalString('text', 0, 2000) &&
        isValidOptionalString('image', 0, 1000000) &&
        isValidOptionalString('video', 0, 1000000) &&
        isValidOptionalString('music', 0, 1000000) &&
        request.resource.data.createdAt is timestamp;
    }

    function isValidCommunity() {
      return hasRequiredFields(['name', 'username', 'ownerId', 'followersCount', 'createdAt']) &&
        isValidStringLength('name', 1, 100) &&
        isValidStringLength('username', 1, 50) &&
        request.resource.data.ownerId == request.auth.uid &&
        isValidOptionalString('description', 0, 1000) &&
        isValidOptionalString('coverImage', 0, 1000000) &&
        request.resource.data.followersCount is number &&
        (!( 'isAdmin' in request.resource.data ) || request.resource.data.isAdmin is bool) &&
        (!( 'isVerified' in request.resource.data ) || request.resource.data.isVerified is bool) &&
        (!( 'isMuted' in request.resource.data ) || request.resource.data.isMuted is bool) &&
        (!( 'isBanned' in request.resource.data ) || request.resource.data.isBanned is bool) &&
        (!( 'isFrozen' in request.resource.data ) || request.resource.data.isFrozen is bool) &&
        request.resource.data.createdAt is timestamp;
    }

    function isCommunityPrivilegeUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isVerified', 'isMuted', 'isBanned', 'isFrozen']);
    }

    function isValidCommunityMember() {
      return hasRequiredFields(['userId', 'communityId', 'role', 'joinedAt']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.role in ['member', 'admin', 'owner'] &&
        request.resource.data.joinedAt is timestamp;
    }

    function isValidFriend() {
      return hasRequiredFields(['user1', 'user2', 'status', 'createdAt']) &&
        (request.resource.data.user1 == request.auth.uid || request.resource.data.user2 == request.auth.uid) &&
        request.resource.data.status in ['pending', 'accepted'] &&
        request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged() && (!('isAdmin' in request.resource.data) || isAdmin()) && (!('isVerified' in request.resource.data) || isAdmin()) && (!('isMuted' in request.resource.data) || isAdmin()) && (!('isBanned' in request.resource.data) || isAdmin()) && (!('isFrozen' in request.resource.data) || isAdmin());
      allow update: if (
        (isOwner(userId) && isValidUser() && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']) && isUserPrivilegeUnchanged()) || 
        isAdmin() ||
        (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']) && math.abs(request.resource.data.followersCount - resource.data.followersCount) == 1)
      );
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost();
      allow update: if isAuthenticated() && isValidPostUpdate() && areImmutableFieldsUnchanged(['createdAt', 'userId']);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && isValidChat();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage', 'lastMessageTime', 'updatedAt']);
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && isValidMessage();
      allow update: if false; // Messages cannot be updated
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.senderId;
    }

    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCommunity() && (!('isAdmin' in request.resource.data) || isAdmin()) && (!('isVerified' in request.resource.data) || isAdmin()) && (!('isMuted' in request.resource.data) || isAdmin()) && (!('isBanned' in request.resource.data) || isAdmin()) && (!('isFrozen' in request.resource.data) || isAdmin());
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.ownerId && isCommunityPrivilegeUnchanged()) || 
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount']) && math.abs(request.resource.data.followersCount - resource.data.followersCount) == 1)
      ) && areImmutableFieldsUnchanged(['createdAt', 'ownerId']);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.ownerId || isAdmin());
    }

    match /communityMembers/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidCommunityMember();
      allow update: if isAuthenticated() && (request.auth.uid == get(/databases/$(database)/documents/communities/$(resource.data.communityId)).data.ownerId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/communities/$(resource.data.communityId)).data.ownerId || isAdmin());
    }

    match /friends/{friendId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidFriend();
      allow update: if isAuthenticated() && isValidFriend() && areImmutableFieldsUnchanged(['createdAt', 'user1', 'user2']);
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.user1 || request.auth.uid == resource.data.user2);
    }

    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.followerId == request.auth.uid && request.resource.data.type in ['user', 'community'];
      allow update: if false;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
    }
  }
}
